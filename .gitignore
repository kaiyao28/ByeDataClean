# ── Generated outputs (never commit) ──────────────────────────────────────────
local/
data/raw/*
data/interim/*
data/processed/*
reports/descriptive_summary/*.md
reports/descriptive_summary/*.txt
reports/full_profiles/*.html
reports/full_profiles/*.json
reports/cleaning_logs/*.md
reports/cleaning_logs/*.txt
reports/validation_reports/*.md
reports/validation_reports/*.txt

# Keep directory sentinels
# (data/examples/ is not ignored — all files there are committed)
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!reports/descriptive_summary/.gitkeep
!reports/full_profiles/.gitkeep
!reports/cleaning_logs/.gitkeep
!reports/validation_reports/.gitkeep

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.so

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── R ─────────────────────────────────────────────────────────────────────────
.Rhistory
.RData
.Rproj.user/
*.Rproj

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── Editors ───────────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
